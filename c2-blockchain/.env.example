# C2 Server
C2_DB_PATH=./c2.db
C2_REDIS_ADDR=localhost:6379
C2_PORT=8443
C2_INSECURE=true
C2_TLS_CERT=./certs/server.crt
C2_TLS_KEY=./certs/server.key
C2_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
C2_JWT_SECRET=lab-jwt-secret-change-in-production
C2_OPERATOR_USER=operator
C2_OPERATOR_PASS=lab
# Tras deploy en Amoy — ver docs/demo/README.md
C2_REGISTRY_ADDRESS=0x629238eD79c23267fe502AAd81E5AEfee3908750
C2_RPC_URL=https://rpc-amoy.polygon.technology
C2_OPERATOR_WALLET_KEY=

# Agent — use http:// when C2_INSECURE=true (server sin TLS)
C2_SERVER_URL=http://localhost:8443
